<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PACS Liquidity & Cash Flow Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap');

  :root {
    --bg:         #0D1117;
    --bg2:        #161B22;
    --bg3:        #1C2430;
    --border:     #2D3748;
    --accent:     #2DB87A;
    --accent2:    #1A8F5C;
    --warn:       #F5A623;
    --danger:     #E05252;
    --info:       #4A9EEB;
    --text:       #E6EDF3;
    --muted:      #8B949E;
    --green-glow: rgba(45,184,122,0.12);
    --font:       'IBM Plex Sans', sans-serif;
    --mono:       'IBM Plex Mono', monospace;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 14px; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── TOP NAV ── */
  nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 28px;
    height: 56px;
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; z-index: 100;
  }
  .nav-left { display: flex; align-items: center; gap: 16px; }
  .nav-logo {
    font-size: 11px; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--accent);
    font-family: var(--mono);
  }
  .nav-divider { width: 1px; height: 20px; background: var(--border); }
  .nav-title { font-size: 13px; color: var(--muted); font-weight: 400; }
  .nav-right { display: flex; align-items: center; gap: 20px; }
  .nav-badge {
    font-size: 11px; font-family: var(--mono);
    padding: 3px 10px; border-radius: 20px;
    background: var(--green-glow); border: 1px solid var(--accent2);
    color: var(--accent);
  }
  .nav-pacs { font-size: 12px; color: var(--muted); }

  /* ── FILTER BAR ── */
  .filterbar {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 28px;
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }
  .filter-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; }
  .btn-group { display: flex; gap: 4px; }
  .btn {
    font-size: 12px; font-family: var(--font); padding: 5px 14px;
    border-radius: 6px; border: 1px solid var(--border);
    background: transparent; color: var(--muted); cursor: pointer; transition: all .15s;
  }
  .btn:hover { border-color: var(--accent); color: var(--accent); }
  .btn.active { background: var(--accent); border-color: var(--accent); color: #000; font-weight: 600; }
  .btn-warn { border-color: var(--warn); color: var(--warn); font-size: 11px; padding: 4px 12px; }
  .spacer { flex: 1; }
  .last-updated { font-size: 11px; color: var(--muted); font-family: var(--mono); }

  /* ── LAYOUT ── */
  .main { padding: 20px 28px; display: flex; flex-direction: column; gap: 20px; }

  /* ── KPI STRIP ── */
  .kpi-strip { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; }
  .kpi {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 10px; padding: 16px 18px;
    position: relative; overflow: hidden;
    transition: border-color .2s;
  }
  .kpi:hover { border-color: var(--accent2); }
  .kpi::before {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
  }
  .kpi.green::before { background: var(--accent); }
  .kpi.warn::before  { background: var(--warn); }
  .kpi.danger::before{ background: var(--danger); }
  .kpi.info::before  { background: var(--info); }
  .kpi-label { font-size: 10px; text-transform: uppercase; letter-spacing: .1em; color: var(--muted); margin-bottom: 8px; }
  .kpi-value { font-size: 22px; font-weight: 600; font-family: var(--mono); line-height: 1.1; }
  .kpi-value.green { color: var(--accent); }
  .kpi-value.warn  { color: var(--warn); }
  .kpi-value.danger{ color: var(--danger); }
  .kpi-value.info  { color: var(--info); }
  .kpi-sub { font-size: 11px; color: var(--muted); margin-top: 6px; }
  .kpi-delta {
    display: inline-flex; align-items: center; gap: 3px;
    font-size: 11px; font-family: var(--mono);
    padding: 1px 6px; border-radius: 4px; margin-top: 4px;
  }
  .kpi-delta.up   { background: rgba(45,184,122,.15); color: var(--accent); }
  .kpi-delta.down { background: rgba(224,82,82,.15);  color: var(--danger); }
  .kpi-source { font-size: 9px; color: #555; margin-top: 6px; font-family: var(--mono); }

  /* ── GRID ── */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .grid-3 { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; }

  /* ── CARD ── */
  .card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 10px; padding: 20px;
  }
  .card-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 16px; }
  .card-title { font-size: 13px; font-weight: 600; color: var(--text); }
  .card-sub   { font-size: 11px; color: var(--muted); margin-top: 2px; }
  .card-tag {
    font-size: 10px; font-family: var(--mono); padding: 2px 8px;
    border-radius: 4px; border: 1px solid var(--border); color: var(--muted);
  }
  .card-tag.green { border-color: var(--accent2); color: var(--accent); background: var(--green-glow); }
  .chart-wrap { position: relative; }

  /* ── TABLE ── */
  .data-table { width: 100%; border-collapse: collapse; font-size: 12px; }
  .data-table th {
    text-align: left; padding: 8px 10px;
    font-size: 10px; text-transform: uppercase; letter-spacing: .08em;
    color: var(--muted); border-bottom: 1px solid var(--border); font-weight: 500;
  }
  .data-table td { padding: 9px 10px; border-bottom: 1px solid rgba(45,55,72,.5); vertical-align: middle; }
  .data-table tr:last-child td { border-bottom: none; }
  .data-table tr:hover td { background: rgba(255,255,255,.02); }
  .pill {
    display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 10px;
    font-weight: 600; font-family: var(--mono);
  }
  .pill-green  { background: rgba(45,184,122,.15); color: var(--accent); }
  .pill-warn   { background: rgba(245,166,35,.15);  color: var(--warn); }
  .pill-danger { background: rgba(224,82,82,.15);   color: var(--danger); }
  .pill-info   { background: rgba(74,158,235,.15);  color: var(--info); }
  .bar-mini { height: 6px; border-radius: 3px; background: var(--border); overflow: hidden; width: 80px; }
  .bar-mini-fill { height: 100%; border-radius: 3px; background: var(--accent); transition: width .4s; }
  .bar-mini-fill.warn   { background: var(--warn); }
  .bar-mini-fill.danger { background: var(--danger); }

  /* ── ALERT PANEL ── */
  .alert {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 12px 16px; border-radius: 8px; margin-bottom: 10px;
    border-left: 3px solid;
  }
  .alert.warn   { background: rgba(245,166,35,.08);  border-color: var(--warn); }
  .alert.danger { background: rgba(224,82,82,.08);   border-color: var(--danger); }
  .alert.info   { background: rgba(74,158,235,.08);  border-color: var(--info); }
  .alert.green  { background: rgba(45,184,122,.08);  border-color: var(--accent); }
  .alert-icon { font-size: 16px; margin-top: 1px; }
  .alert-title { font-size: 12px; font-weight: 600; margin-bottom: 2px; }
  .alert.warn   .alert-title { color: var(--warn); }
  .alert.danger .alert-title { color: var(--danger); }
  .alert.info   .alert-title { color: var(--info); }
  .alert.green  .alert-title { color: var(--accent); }
  .alert-body { font-size: 11px; color: var(--muted); line-height: 1.5; }
  .alert-source { font-size: 9px; color: #555; font-family: var(--mono); margin-top: 4px; }

  /* ── WATERFALL ── */
  .waterfall-wrap { overflow-x: auto; }

  /* ── FORECAST TABLE ── */
  .forecast-grid {
    display: grid; grid-template-columns: 100px repeat(8, 1fr);
    gap: 1px; background: var(--border); border-radius: 8px; overflow: hidden;
    font-size: 11px; font-family: var(--mono);
  }
  .fg-cell {
    background: var(--bg3); padding: 8px 10px; text-align: right;
  }
  .fg-cell.label { text-align: left; color: var(--muted); font-family: var(--font); }
  .fg-cell.header { background: #1A2535; color: var(--muted); font-size: 10px; text-transform: uppercase; }
  .fg-cell.section { background: #141B25; color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: .06em; font-family: var(--font); }
  .fg-cell.total   { background: #12201A; color: var(--accent); font-weight: 600; }
  .fg-cell.total.label { color: var(--accent); }
  .fg-cell.net     { font-weight: 600; }
  .fg-cell.net.pos { color: var(--accent); }
  .fg-cell.net.neg { color: var(--danger); }
  .fg-cell.forecast { color: var(--warn); }
  .forecast-legend { display: flex; gap: 16px; margin-top: 10px; }
  .legend-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; }

  /* ── SEASON INDICATOR ── */
  .season-band {
    display: grid; grid-template-columns: repeat(12, 1fr);
    gap: 4px; margin-bottom: 6px;
  }
  .season-cell {
    text-align: center; font-size: 10px; padding: 4px 2px; border-radius: 4px;
  }
  .season-cell.kharif  { background: rgba(45,184,122,.2); color: var(--accent); }
  .season-cell.rabi    { background: rgba(74,158,235,.2); color: var(--info); }
  .season-cell.offpeak { background: rgba(45,55,72,.4);   color: var(--muted); }

  /* ── DCCB PANEL ── */
  .dccb-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .dccb-item {
    background: var(--bg3); border: 1px solid var(--border); border-radius: 8px;
    padding: 14px; position: relative;
  }
  .dccb-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 6px; }
  .dccb-val { font-size: 18px; font-weight: 600; font-family: var(--mono); }
  .dccb-source { font-size: 9px; color: #555; font-family: var(--mono); margin-top: 4px; }

  /* ── PRODUCT BREAKDOWN ── */
  .product-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .product-name { width: 120px; font-size: 12px; color: var(--text); }
  .product-bar { flex: 1; height: 8px; border-radius: 4px; background: var(--border); overflow: hidden; }
  .product-fill { height: 100%; border-radius: 4px; }
  .product-val { width: 80px; text-align: right; font-size: 12px; font-family: var(--mono); color: var(--muted); }

  /* ── FOOTER ── */
  footer {
    text-align: center; padding: 20px;
    font-size: 10px; color: #444;
    font-family: var(--mono);
    border-top: 1px solid var(--border);
    margin-top: 8px;
  }
  footer span { color: #555; }

  /* ── RESPONSIVE ── */
  @media (max-width: 1100px) {
    .kpi-strip { grid-template-columns: repeat(3, 1fr); }
    .grid-2, .grid-3 { grid-template-columns: 1fr; }
  }
  @media (max-width: 700px) {
    .main { padding: 12px; }
    nav { padding: 0 14px; }
    .filterbar { padding: 8px 14px; }
    .kpi-strip { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-left">
    <div class="nav-logo">NABARD · PACS</div>
    <div class="nav-divider"></div>
    <div class="nav-title">Liquidity Management &amp; Cash Flow Forecasting</div>
  </div>
  <div class="nav-right">
    <div class="nav-badge">● LIVE</div>
    <div class="nav-pacs">Rabi Season 2024–25 · Maharashtra</div>
  </div>
</nav>

<!-- FILTER BAR -->
<div class="filterbar">
  <span class="filter-label">Period</span>
  <div class="btn-group">
    <button class="btn" onclick="setPeriod(this,'weekly')">Weekly</button>
    <button class="btn active" onclick="setPeriod(this,'monthly')">Monthly</button>
    <button class="btn" onclick="setPeriod(this,'quarterly')">Quarterly</button>
  </div>
  <span class="filter-label" style="margin-left:12px">Season</span>
  <div class="btn-group">
    <button class="btn active" onclick="setSeason(this,'all')">All Year</button>
    <button class="btn" onclick="setSeason(this,'kharif')">Kharif</button>
    <button class="btn" onclick="setSeason(this,'rabi')">Rabi</button>
  </div>
  <span class="filter-label" style="margin-left:12px">PACS Cluster</span>
  <div class="btn-group">
    <button class="btn active">All PACS</button>
    <button class="btn">Cluster A</button>
    <button class="btn">Cluster B</button>
    <button class="btn">Cluster C</button>
  </div>
  <div class="spacer"></div>
  <div class="last-updated">Day-end: 15-Jan-2025 · <span style="color:var(--accent)">fa_societydaybookdailybalances</span></div>
</nav>

<!-- MAIN -->
<div class="main">

  <!-- KPI STRIP -->
  <div class="kpi-strip">
    <div class="kpi green">
      <div class="kpi-label">Current Liquidity Balance</div>
      <div class="kpi-value green">₹4.82 Cr</div>
      <div class="kpi-delta up">▲ 8.4% vs last week</div>
      <div class="kpi-source">fa_societydaybookdailybalances · fa_generalledgerbalance</div>
    </div>
    <div class="kpi warn">
      <div class="kpi-label">Upcoming Outflows (30d)</div>
      <div class="kpi-value warn">₹7.34 Cr</div>
      <div class="kpi-sub">Disbursals + Procurement Pmts</div>
      <div class="kpi-source">br_demandcollectionbalancedetails · fa_loantransactiondetails</div>
    </div>
    <div class="kpi green">
      <div class="kpi-label">Expected Inflows (30d)</div>
      <div class="kpi-value green">₹6.91 Cr</div>
      <div class="kpi-sub">Repayments + Deposits</div>
      <div class="kpi-source">de_In_dcbstatement · fa_otherdeposittransactions</div>
    </div>
    <div class="kpi danger">
      <div class="kpi-label">Projected Liquidity Gap</div>
      <div class="kpi-value danger">–₹0.43 Cr</div>
      <div class="kpi-sub">Refinancing needed from DCCB</div>
      <div class="kpi-source">br_outstanding · br_borrowingdisbursment</div>
    </div>
    <div class="kpi info">
      <div class="kpi-label">CD Ratio</div>
      <div class="kpi-value info">78.4%</div>
      <div class="kpi-delta up">▲ 2.1 pts this month</div>
      <div class="kpi-source">fa_modulebalances · fa_otherdeposittransactions</div>
    </div>
  </div>

  <!-- ALERT PANEL -->
  <div>
    <div class="alert danger">
      <div class="alert-icon">⚠</div>
      <div>
        <div class="alert-title">Liquidity Stress Alert — Rabi Procurement Peak (Feb 2025)</div>
        <div class="alert-body">Projected net cash position turns negative by Feb 14. ₹0.43 Cr refinancing request recommended to DCCB by Jan 28 to cover procurement payment obligations for wheat MSP operations.</div>
        <div class="alert-source">Source: fa_societydaybookdailybalances + br_demandcollectionbalancedetails + cm_financialyearstatus</div>
      </div>
    </div>
    <div class="alert warn">
      <div class="alert-icon">◑</div>
      <div>
        <div class="alert-title">3 PACS clusters have CD Ratio &gt; 90% — elevated deployment risk</div>
        <div class="alert-body">Clusters B, C, and F show credit-to-deposit ratios above 90%, indicating over-deployment. Monitor deposit mobilization to prevent withdrawal-driven liquidity events.</div>
        <div class="alert-source">Source: fa_modulebalances · fa_generalledgerbalance</div>
      </div>
    </div>
    <div class="alert green">
      <div class="alert-icon">✓</div>
      <div>
        <div class="alert-title">Repayment collection on track — 84% recovery rate this month</div>
        <div class="alert-body">Demand-collection-balance (DCB) statement shows ₹3.2 Cr collected against ₹3.8 Cr demand. Seasonal repayment pattern within expected range for post-kharif harvest period.</div>
        <div class="alert-source">Source: de_In_dcbstatement · br_demandcollectionbalancedetails</div>
      </div>
    </div>
  </div>

  <!-- CASH FLOW CHART + SEASONAL BAND -->
  <div class="card">
    <div class="card-header">
      <div>
        <div class="card-title">Monthly Cash Flow — Actuals vs Forecast (FY 2024–25)</div>
        <div class="card-sub">Inflows: repayments + deposit mobilisation &nbsp;|&nbsp; Outflows: disbursals + procurement payments + borrowing repayments</div>
      </div>
      <div style="display:flex;gap:8px">
        <span class="card-tag green">fa_societydaybookdailybalances</span>
        <span class="card-tag">fa_cashflowstatement</span>
      </div>
    </div>

    <!-- Season band -->
    <div class="season-band">
      <div class="season-cell offpeak">Apr</div>
      <div class="season-cell offpeak">May</div>
      <div class="season-cell kharif">Jun<br><span style="font-size:8px">Kharif</span></div>
      <div class="season-cell kharif">Jul</div>
      <div class="season-cell kharif">Aug</div>
      <div class="season-cell kharif">Sep</div>
      <div class="season-cell rabi">Oct<br><span style="font-size:8px">Rabi</span></div>
      <div class="season-cell rabi">Nov</div>
      <div class="season-cell rabi">Dec</div>
      <div class="season-cell rabi">Jan</div>
      <div class="season-cell rabi">Feb</div>
      <div class="season-cell offpeak">Mar</div>
    </div>

    <div class="chart-wrap" style="height:240px">
      <canvas id="cashflowChart"></canvas>
    </div>
    <div style="display:flex;gap:20px;margin-top:12px;flex-wrap:wrap">
      <span style="font-size:11px;color:var(--accent)">■ Inflow (Actual)</span>
      <span style="font-size:11px;color:var(--danger)">■ Outflow (Actual)</span>
      <span style="font-size:11px;color:rgba(45,184,122,.4)">▨ Inflow (Forecast)</span>
      <span style="font-size:11px;color:rgba(224,82,82,.4)">▨ Outflow (Forecast)</span>
      <span style="font-size:11px;color:var(--warn)">— Net Position</span>
    </div>
  </div>

  <!-- NET CASH + BORROWINGS CHART -->
  <div class="grid-2">
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Daily Liquidity Position — Last 60 Days</div>
          <div class="card-sub">End-of-day cash balance from day-close records</div>
        </div>
        <span class="card-tag green">fa_societydaybookdailybalances</span>
      </div>
      <div class="chart-wrap" style="height:200px">
        <canvas id="dailyLiqChart"></canvas>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Inflow Breakdown — Current Month</div>
          <div class="card-sub">By source category</div>
        </div>
        <span class="card-tag">de_In_dcbstatement</span>
      </div>
      <div style="display:flex;align-items:center;gap:20px">
        <div class="chart-wrap" style="height:180px;width:180px;flex-shrink:0">
          <canvas id="inflowPie"></canvas>
        </div>
        <div style="flex:1">
          <div class="product-row">
            <div class="product-name">Loan Repayments</div>
            <div class="product-bar"><div class="product-fill" style="width:68%;background:var(--accent)"></div></div>
            <div class="product-val">₹2.34 Cr</div>
          </div>
          <div class="product-row">
            <div class="product-name">Deposit Inflow</div>
            <div class="product-bar"><div class="product-fill" style="width:22%;background:var(--info)"></div></div>
            <div class="product-val">₹0.76 Cr</div>
          </div>
          <div class="product-row">
            <div class="product-name">DCCB Refinance</div>
            <div class="product-bar"><div class="product-fill" style="width:7%;background:var(--warn)"></div></div>
            <div class="product-val">₹0.24 Cr</div>
          </div>
          <div class="product-row">
            <div class="product-name">Share Capital</div>
            <div class="product-bar"><div class="product-fill" style="width:3%;background:var(--muted)"></div></div>
            <div class="product-val">₹0.10 Cr</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 8-WEEK FORECAST TABLE + BORROWING DETAILS -->
  <div class="grid-3">
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">8-Week Rolling Cash Flow Forecast</div>
          <div class="card-sub">Weeks with projected negative net balance are flagged for DCCB refinancing</div>
        </div>
        <span class="card-tag green">fa_dayend · br_demandcollectionbalancedetails</span>
      </div>

      <div class="forecast-legend" style="margin-bottom:12px">
        <span style="font-size:11px;color:var(--text)"><span class="legend-dot" style="background:var(--text);display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:4px"></span>Actual</span>
        <span style="font-size:11px;color:var(--warn)"><span class="legend-dot" style="background:var(--warn);display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:4px"></span>Forecast</span>
      </div>

      <div class="forecast-grid">
        <!-- header -->
        <div class="fg-cell header label">₹ Lakhs</div>
        <div class="fg-cell header">W1 Jan13</div>
        <div class="fg-cell header">W2 Jan20</div>
        <div class="fg-cell header">W3 Jan27</div>
